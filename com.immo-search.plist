<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.immo-search</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/wallaceespindola/git/immo-search/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/wallaceespindola/git/immo-search</string>

    <!-- Daily at 07:30 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/wallaceespindola/git/immo-search/logs/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/wallaceespindola/git/immo-search/logs/launchd.error.log</string>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <!-- Retry if missed (e.g. computer was off) -->
    <key>StartInterval</key>
    <integer>86400</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    </dict>
</dict>
</plist>

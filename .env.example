# =============================================================================
# immo-search — environment configuration example
# Copy to .env and fill in your values
# =============================================================================

# =============================================================================
# Gmail SMTP configuration
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail account used to send alerts
GMAIL_USER=your.alerts@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification enabled on the sending account
GMAIL_APP_PASSWORD='xxxx xxxx xxxx xxxx'

# Email address that receives the alerts
EMAIL_TO=your.email@gmail.com


# =============================================================================
# Search criteria
# =============================================================================

MAX_PRICE=600000
MIN_BEDROOMS=4
REQUIRE_POOL=true


# =============================================================================
# Monitored Belgian real estate sites
# Comma-separated list of active source names.
# Remove any site to disable it.
# =============================================================================

# Tier 1 — Core market coverage
IMMO_SITES_TIER1=Immoweb,Zimmo,Immovlan

# Tier 2 — Opportunity sources
IMMO_SITES_TIER2=Immoscoop,Logic-Immo,Biddit

# Tier 3 — Aggregators
IMMO_SITES_TIER3=Realo,Trovit,eRowz,Century21

# All active sites (controls which scrapers actually run)
IMMO_SITES_ACTIVE=Immoweb,Zimmo,Immovlan,Immoscoop,Logic-Immo,Biddit,Realo,Trovit,eRowz,Century21


# =============================================================================
# Target cities — Brabant Wallon (primary search area)
# =============================================================================

TARGET_CITIES_BW=Wavre,Limal,Ottignies,Louvain-la-Neuve,Rixensart,La Hulpe,Waterloo,Braine-l'Alleud,Nivelles,Genappe,Genval,Lasne,Court-Saint-Étienne,Villers-la-Ville,Chastre,Mont-Saint-Guibert,Walhain,Perwez


# =============================================================================
# Target cities — Province de Namur
# =============================================================================

TARGET_CITIES_NAMUR=Namur,Jambes,Gembloux,Floreffe,Profondeville,Andenne,Sambreville,Fosses-la-Ville,Mettet,Ciney,Dinant,Rochefort,Philippeville,Couvin,Walcourt,Florennes,Eghezée,Fernelmont


# =============================================================================
# Target cities — Brabant Flamand (bordering municipalities)
# =============================================================================

TARGET_CITIES_VBR=Leuven,Tervuren,Overijse,Hoeilaart,Huldenberg,Oud-Heverlee,Ottenburg,Sint-Genesius-Rode,Rhode-Saint-Genèse,Linkebeek,Beersel,Drogenbos,Wemmel


# =============================================================================
# Postal codes — Brabant Wallon
# =============================================================================

POSTAL_CODES_BW=1300,1301,1325,1330,1331,1332,1340,1341,1342,1348,1310,1380,1390,1400,1401,1402,1410,1420,1421,1428,1470,1471,1473,1490,1495,1450,1454,1360,1370


# =============================================================================
# Postal codes — Province de Namur (selected municipalities)
# =============================================================================

POSTAL_CODES_NAMUR=5000,5001,5002,5003,5004,5010,5020,5030,5031,5032,5060,5070,5080,5100,5101,5140,5150,5170,5190,5300,5310,5330,5340,5350,5360,5370,5380


# =============================================================================
# Postal codes — Brabant Flamand (bordering municipalities)
# =============================================================================

POSTAL_CODES_VBR=3001,3010,3018,3050,3053,3054,3060,3061,3070,3080,3090,1560,1600,1620,1630,1640,1650,1654,1670,1500,1501,1502


# =============================================================================
# Search keywords — French (inclusion — property types to keep)
# =============================================================================

KEYWORDS_INCLUDE_FR=maison 4 façades,maison 4 facades,villa,maison individuelle,maison isolée,maison isolee,propriété,propriete,villa indépendante,villa independante,4 façades,4 facades


# =============================================================================
# Search keywords — Dutch / Flemish (inclusion)
# =============================================================================

KEYWORDS_INCLUDE_NL=open bebouwing,vrijstaande woning,alleenstaande woning,villa,open huis,4 gevels


# =============================================================================
# Exclusion keywords — French (property types to discard)
# =============================================================================

KEYWORDS_EXCLUDE_FR=appartement,studio,duplex,triplex,penthouse,rez-de-chaussée,rez-de-chaussee,immeuble à appartements,immeuble a appartements,maison mitoyenne,2 façades,2 facades,3 façades,3 facades,maison de rangée,maison de rangee


# =============================================================================
# Exclusion keywords — Dutch
# =============================================================================

KEYWORDS_EXCLUDE_NL=appartement,studio,duplex,penthouse,rijwoning,gesloten bebouwing,halfopen bebouwing,2 gevels,3 gevels


# =============================================================================
# Pool keywords — used to detect swimming pool mentions in listings
# =============================================================================

KEYWORDS_POOL_FR=piscine,piscine extérieure,piscine chauffée,piscine privée,avec piscine
KEYWORDS_POOL_NL=zwembad,verwarmd zwembad,privé zwembad,met zwembad


# =============================================================================
# HTTP scraping settings (optional — defaults shown)
# =============================================================================

# Seconds before a request times out
REQUEST_TIMEOUT=20

# Random delay between requests to avoid rate-limiting (seconds)
REQUEST_DELAY_MIN=1.5
REQUEST_DELAY_MAX=3.5
